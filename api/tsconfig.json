{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    // Nest runs on CommonJS — override the base's ESNext/Bundler settings.
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "lib": ["ES2022"],
    "types": ["node", "jest"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // Decorator metadata + DI need these relaxed vs. the strict base.
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "sourceMap": true,
    // incremental disabled: nest's deleteOutDir wipes dist/ but not the
    // .tsbuildinfo, so incremental builds would skip emit and leave dist/ empty.
    "incremental": false,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

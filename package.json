{
  "name": "drilliq",
  "version": "0.1.0",
  "private": true,
  "description": "DrillIQ — drill-bit performance & daily-drilling-report analytics platform",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @drilliq/web --filter @drilliq/api dev",
    "build": "pnpm --filter @drilliq/db build && pnpm --filter @drilliq/api build && pnpm --filter @drilliq/web build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @drilliq/db migrate",
    "db:generate": "pnpm --filter @drilliq/db generate",
    "db:seed": "pnpm --filter @drilliq/db seed",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down"
  }
}

# ---- Database (PostgreSQL) ----
# RLS requires the API to connect as a NON-owner, NON-BYPASSRLS role.
# Host is 127.0.0.1 (not localhost): on some hosts localhost resolves to ::1 (IPv6)
# first and Docker's IPv6 port proxy is unreachable -> Prisma P1001. 127.0.0.1 forces IPv4.
# (For the fully containerized `docker compose up` stack, the API reaches Postgres at host `db`.)
POSTGRES_USER=drilliq
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=drilliq
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# App connects as the restricted RLS role (NOT the owner).
DATABASE_URL=postgresql://drilliq_app:change-me-app@127.0.0.1:5432/drilliq?schema=public
# Migration/owner role (used only by `prisma migrate`).
DATABASE_URL_MIGRATE=postgresql://drilliq:change-me-in-prod@127.0.0.1:5432/drilliq?schema=public

# ---- API ----
API_PORT=3000
NODE_ENV=development
# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900          # 15 min
JWT_REFRESH_TTL=604800      # 7 days

# ---- Web ----
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:3000

# ---- ML service (FastAPI, deferred) ----
ML_PORT=8000
ML_BASE_URL=http://localhost:8000

# ---- Reporting ----
# Puppeteer downloads its own Chromium by default; set to skip + use system chrome on-prem.
PUPPETEER_SKIP_DOWNLOAD=false
REPORTS_OUTPUT_DIR=/tmp/drilliq-reports
